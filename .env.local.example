# Copy this file to `.env.local` and fill in your real keys before going live.
# cp .env.local.example .env.local

# ── Supabase ──────────────────────────────────────────────
# Get from: supabase.com → Project Settings → API
# Use the Project URL WITHOUT /rest/v1/ at the end
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# ── Admin Panel Password ──────────────────────────────────
# Your client uses this to log in at yoursite.com/admin
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD
